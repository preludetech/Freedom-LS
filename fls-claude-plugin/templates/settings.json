{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(find:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run git commit:*)",
      "mcp__playwright__*",
      "mcp__ide__getDiagnostics",
      "Bash(tail:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Bash(npm run tailwind_build)",
      "Bash(sleep 3:*)",
      "Bash(sleep 3 && curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:*)",
      "Skill(frontend-styling)",
      "Skill(template)",
      "Skill(icon-usage)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(config/settings_prod.py)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  }
}
