{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show *)",
      "Bash(find:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run git commit:*)",
      "mcp__playwright__*",
      "mcp__ide__getDiagnostics",
      "Bash(tail:*)",
      "Bash(uv run git status:*)",
      "Bash(uv run git mv:*)",
      "Bash(uv run ruff check:*)",
      "Bash(uv run ruff format:*)",
      "Bash(git add:*)",
      "Bash(uv run git add *)",
      "Bash(uv run git push:*)",
      "Bash(git fetch:*)",
      "Bash(git push *)",
      "Bash(git stash:*)",
      "Bash(git rebase *)",
      "Bash(gh pr:*)",
      "Bash(ls:*)",
      "Bash(npm run tailwind_build:*)",
      "mcp__plugin_ds_playwright__*",
      "Skill(ds:*)",
      "Skill(fls-dev:*)",
      "Skill(sdd:*)",
      "WebFetch",
      "WebSearch",
      "Bash(grep *)",
      "Bash(.claude/ds/scripts/fetch_pr_comments.sh *)",
      "Bash(.claude/ds/scripts/kill_runserver.sh:*)",
      "Bash(git rm *)",
      "Bash(git grep *)",
      "Bash(.claude/fls-dev/scripts/dev_db_delete.sh:*)",
      "Bash(git ls-files *)",
      "Bash(git rev-parse *)",
      "Bash(git mv *)",
      "Bash(chmod +x *)",
      "Bash(GIT_EDITOR=true git rebase --continue)",
      "Bash(rm -f .sdd-work/*)",
      "Bash(rmdir .sdd-work)",
      "Bash(git branch *)",
      "Bash(git remote *)",
      "Bash(jobs)"
    ],
    "deny": [
      "Write(config/settings_prod.py)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(.env)"
    ]
  },
  "enabledPlugins": {
    "ds": true,
    "fls-dev": true,
    "sdd": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "if": "Read(.env*)",
            "command": "f=$(jq -r '.tool_input.file_path // empty'); case \"${f##*/}\" in .env.example) ;; .env|.env.*) printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Reading .env secret files is blocked; only .env.example may be read.\"}}' ;; esac"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$CLAUDE_PLUGINS_LOADED\" ] || printf '%s' '{\"systemMessage\":\"\\n\\n============================================================\\n\\n   !!!  PLUGINS NOT LOADED  !!!\\n\\n============================================================\\n\\n   YOUR SESSION WILL NOT WORK CORRECTLY.\\n\\n   FIX:\\n     1. Quit Claude (press Ctrl+C twice)\\n     2. Run:  ./claude.sh\\n        NOT:  claude\\n\\n============================================================\\n\\n\",\"continue\":false}'"
          }
        ]
      }
    ]
  }
}
