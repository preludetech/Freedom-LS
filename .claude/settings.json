{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(find:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run git commit:*)",
      "mcp__playwright__*",
      "mcp__ide__getDiagnostics",
      "Skill(frontend-styling)",
      "Bash(tail:*)",
      "Bash(sleep 3:*)",
      "Bash(git add:*)",
      "Bash(ls:*)",
      "Skill(template)",
      "Skill(icon-usage)",
      "Bash(npm run tailwind_build)",
      "Bash(sleep 3 && curl -s -o /dev/null -w \"%{http_code}\" http://127.0.0.1:*)",
      "mcp__plugin_fls_playwright__*",
      "Skill(fls:sdd:protected:update_todo)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(config/settings_prod.py)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "enabledPlugins": {
    "fls": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$FLS_PLUGIN\" ] || printf '%s' '{\"systemMessage\":\"\\n\\n============================================================\\n\\n   !!!  FLS PLUGIN NOT LOADED  !!!\\n\\n============================================================\\n\\n   YOUR SESSION WILL NOT WORK CORRECTLY.\\n\\n   FIX:\\n     1. Quit Claude (press Ctrl+C twice)\\n     2. Run:  ./claude.sh\\n        NOT:  claude\\n\\n============================================================\\n\\n\",\"continue\":false}'"
          }
        ]
      }
    ]
  }
}
