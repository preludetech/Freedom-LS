{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(find:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run git commit:*)",
      "mcp__playwright__*",
      "mcp__ide__getDiagnostics",
      "Bash(tail:*)",
      "Bash(uv run git commit:*)",
      "Bash(uv run git status:*)",
      "Bash(uv run ruff check)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git push *)",
      "Bash(git stash:*)",
      "Bash(git rebase *)",
      "Bash(gh pr:*)",
      "Bash(ls:*)",
      "Bash(npm run tailwind_build:*)",
      "mcp__plugin_fls_playwright__*",
      "Skill(fls:*)",
      "WebFetch",
      "WebSearch",
      "Bash(grep *)",
      "Bash(.claude/fls/scripts/fetch_pr_comments.sh *)",
      "Bash(.claude/fls/scripts/kill_runserver.sh:*)",
      "Bash(git rm *)",
      "Bash(git grep *)",
      "Bash(.claude/fls/scripts/dev_db_delete.sh:*)",
      "Bash(git ls-files *)",
      "Bash(GIT_EDITOR=true git rebase --continue)",
      "Bash(rm -f .sdd-work/*)",
      "Bash(rmdir .sdd-work)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(config/settings_prod.py)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "enabledPlugins": {
    "fls": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$FLS_PLUGIN\" ] || printf '%s' '{\"systemMessage\":\"\\n\\n============================================================\\n\\n   !!!  FLS PLUGIN NOT LOADED  !!!\\n\\n============================================================\\n\\n   YOUR SESSION WILL NOT WORK CORRECTLY.\\n\\n   FIX:\\n     1. Quit Claude (press Ctrl+C twice)\\n     2. Run:  ./claude.sh\\n        NOT:  claude\\n\\n============================================================\\n\\n\",\"continue\":false}'"
          }
        ]
      }
    ]
  }
}
