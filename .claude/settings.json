{
  "permissions": {
    "_comment_qa_scripts": "Any script placed in .claude/fls/scripts/ is thereby granted prompt-free QA execution with arbitrary arguments via the Bash(.claude/fls/scripts/* *) wildcard, and must be reviewed as security-sensitive — equivalent to adding an allow-list entry.",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(find:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run git commit:*)",
      "mcp__playwright__*",
      "mcp__ide__getDiagnostics",
      "Bash(tail:*)",
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git push *)",
      "Bash(git stash:*)",
      "Bash(git rebase *)",
      "Bash(gh pr:*)",
      "Bash(ls:*)",
      "Bash(npm run tailwind_build:*)",
      "Skill(fls:*)",
      "WebFetch",
      "WebSearch",
      "Bash(grep *)",
      "Bash(.claude/fls/scripts/fetch_pr_comments.sh *)",
      "Bash(.claude/fls/scripts/kill_runserver.sh:*)",
      "Bash(git rm *)",
      "Bash(.claude/fls/scripts/* *)",
      "Bash(.claude/fls/scripts/*)",
      "Bash(uv run python manage.py runserver *)",
      "Bash(uv run --with pillow python * compress_screenshots.py *)",
      "Bash(.claude/fls/scripts/find_available_port.sh*)",
      "Bash(.claude/fls/scripts/qa_cleanup.sh*)",
      "Bash(.claude/fls/scripts/qa_collect_screenshots.sh*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Write(config/settings_prod.py)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --force:*)",
      "Read(**/*.pem)",
      "Read(**/*.key)"
    ]
  },
  "enabledPlugins": {
    "fls": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$FLS_PLUGIN\" ] || printf '%s' '{\"systemMessage\":\"\\n\\n============================================================\\n\\n   !!!  FLS PLUGIN NOT LOADED  !!!\\n\\n============================================================\\n\\n   YOUR SESSION WILL NOT WORK CORRECTLY.\\n\\n   FIX:\\n     1. Quit Claude (press Ctrl+C twice)\\n     2. Run:  ./claude.sh\\n        NOT:  claude\\n\\n============================================================\\n\\n\",\"continue\":false}'"
          }
        ]
      }
    ]
  }
}
