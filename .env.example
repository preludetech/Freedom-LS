# Database Configuration
DB_NAME=lms_db
DB_USER=lms_user
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432
# libpq sslmode. "disable" is correct for the shipped same-host Postgres container,
# which has no TLS listener (the code falls back to "prefer" if this var is unset,
# which also works here since it downgrades to plaintext when there's nothing to
# negotiate with). Set to "require" or "verify-full" only for external/managed
# databases. For the same-host setup, the control that actually matters is not
# publishing port 5432 to the host, not this setting.
DB_SSLMODE=disable
# Persistent connection lifetime in seconds. Recommended 60-300s; never unlimited, which
# lets connections accumulate without bound under load. CONN_HEALTH_CHECKS is on, so
# stale sockets left over after a `db` container restart are recycled rather than reused.
DB_CONN_MAX_AGE=60
SECRET_KEY=50charactersofsupersecret
# secret — required in production; settings_prod fails fast (ImproperlyConfigured)
# on boot if unset. Without it the code falls back to a hardcoded dev salt that
# silently weakens webhook-secret Fernet encryption.
WEBHOOK_ENCRYPTION_SALT=another50charactersofsupersecret

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@example.com
EMAIL_HOST_PASSWORD=your_app_specific_password_here
DEFAULT_FROM_EMAIL=your_email@example.com

HOST_DOMAIN="staging.freedomlearningsystem.org"
# config — default "admin/"; change to a non-guessable path to reduce automated
# scanning noise against the admin login
DJANGO_ADMIN_URL=admin/

# HSTS rollout (see docs/deployment-security-checklist.md for staged values)
# config — default 3600
HSTS_SECONDS=3600
# config — default False
HSTS_INCLUDE_SUBDOMAINS=False
# config — default False
HSTS_PRELOAD=False


# If you are deploying with the docker compose file included here,
# then you'll want to store the postgres data somewhere persistent.

DB_DATA_PATH=~/.lms_postges_prod_data


# -----------------------------------------------------------------------------
# External services (PostHog / Sentry / Cloudflare R2)
#
# See spec_dd/2. in progress/support-concrete-project-deployment/third-party-services.md
# for account setup. Each var below is marked secret (never commit a real
# value) or config (safe to set here / in CI).
# -----------------------------------------------------------------------------

# PostHog analytics — unset POSTHOG_API_KEY disables PostHog entirely
# public token — safe in client-side HTML; per-environment
POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# config — region host, default https://us.i.posthog.com (override for EU)
POSTHOG_API_HOST=https://us.i.posthog.com
# config, optional — only needed for a reverse-proxied PostHog ingestion host
POSTHOG_UI_HOST=

# Sentry error tracking — unset SENTRY_DSN disables Sentry entirely
# secret
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# config — set this whenever SENTRY_DSN is set: the Sentry SDK otherwise
# silently tags every event "production", making staging indistinguishable.
SENTRY_ENVIRONMENT=staging
# config, optional — CI-injected git SHA; unset = no release tag
SENTRY_RELEASE=
# config — default 0.1 (low sample rate for cost control)
SENTRY_TRACES_SAMPLE_RATE=0.1
# config — default False; True attaches learner PII + full request bodies to every event
SENTRY_SEND_DEFAULT_PII=False

# Cloudflare R2 (S3-compatible) media object storage
# config — also the on/off gate: unset uses local FileSystemStorage instead
AWS_STORAGE_BUCKET_NAME=
# secret
AWS_S3_ACCESS_KEY_ID=
# secret
AWS_S3_SECRET_ACCESS_KEY=
# config — e.g. https://<account-id>.r2.cloudflarestorage.com
AWS_S3_ENDPOINT_URL=
# config — default "auto" (R2's region convention)
AWS_S3_REGION_NAME=auto
# config, optional — public opt-in only; set together with AWS_QUERYSTRING_AUTH=False
AWS_S3_CUSTOM_DOMAIN=
# config — default True (private, time-limited signed URLs); False + AWS_S3_CUSTOM_DOMAIN opts into public serving
AWS_QUERYSTRING_AUTH=True
# config — default 3600 (signed-URL lifetime in seconds)
AWS_QUERYSTRING_EXPIRE=3600
